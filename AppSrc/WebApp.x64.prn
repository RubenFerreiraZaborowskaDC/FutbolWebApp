37200>>>>>                
37200>>>>>                If (bMatch) Begin
37202>>>>>                    // Store the login
37202>>>>>                    If (bUpgrade) Begin
37204>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37205>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37208>>>>>                    End
37208>>>>>>
37208>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37209>>>>>                    Get Request_Validate of hoSessionDD to iErr
37210>>>>>                    If (iErr) Begin
37212>>>>>                        // this should not happen. If it does its a programming error
37212>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37213>>>>>>
37213>>>>>                        Function_Return False
37214>>>>>                    End
37214>>>>>>
37214>>>>>                    
37214>>>>>                    Send Request_Save of hoSessionDD
37215>>>>>                    
37215>>>>>                    // Update session properties
37215>>>>>                    Send UpdateSessionProperties False
37216>>>>>                    Send NotifyChangeRights
37217>>>>>                    Function_Return True
37218>>>>>                End
37218>>>>>>
37218>>>>>                Else Begin
37219>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37219>>>>>                    Send Clear of hoUserDD
37220>>>>>                End
37220>>>>>>
37220>>>>>            End
37220>>>>>>
37220>>>>>            Else Begin
37221>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37221>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37222>>>>>            End
37222>>>>>>
37222>>>>>        End
37222>>>>>>
37222>>>>>        Else Begin
37223>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37223>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37224>>>>>        End
37224>>>>>>
37224>>>>>          
37224>>>>>        Function_Return False
37225>>>>>    End_Function
37226>>>>>    
37226>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37228>>>>>        Handle hoUserDD
37228>>>>>        Integer iErr
37228>>>>>        Get phoUserDD to hoUserDD
37229>>>>>        
37229>>>>>        //  Find the user
37229>>>>>        Send Clear of hoUserDD
37230>>>>>        Move sLoginName to WebAppUser.LoginName
37231>>>>>        Send Find of hoUserDD EQ Index.1
37232>>>>>        If (not(Found)) Begin
37234>>>>>            Send Clear of hoUserDD
37235>>>>>            Function_Return False
37236>>>>>        End
37236>>>>>>
37236>>>>>        
37236>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37238>>>>>            Send Clear of hoUserDD
37239>>>>>            Function_Return False
37240>>>>>        End
37240>>>>>>
37240>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37241>>>>>        Get Request_Validate of hoUserDD to iErr
37242>>>>>        If (iErr) Begin
37244>>>>>            Send Clear of hoUserDD
37245>>>>>            Function_Return False
37246>>>>>        End
37246>>>>>>
37246>>>>>        
37246>>>>>        Send Request_Save of hoUserDD
37247>>>>>        Function_Return (not(Err))
37248>>>>>    End_Function
37249>>>>>    
37249>>>>>    Function IsLoggedIn Returns Boolean
37251>>>>>        String sLoginName
37251>>>>>        Boolean bLogWebSession bLoggedIn
37251>>>>>        
37251>>>>>        Get pbLogWebSession to bLogWebSession
37252>>>>>        If not bLogWebSession Begin
37254>>>>>            Forward Get IsLoggedIn to bLoggedIn
37256>>>>>            Function_Return bLoggedIn
37257>>>>>        End
37257>>>>>>
37257>>>>>        
37257>>>>>        Get psLoginName to sLoginName
37258>>>>>        
37258>>>>>        Function_Return (sLoginName <> "")
37259>>>>>    End_Function
37260>>>>>    
37260>>>>>    
37260>>>>>    //
37260>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37260>>>>>    // update properties based on the session and user data. Augment this function to update 
37260>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37260>>>>>    // the right records when this procedure is called.
37260>>>>>    //
37260>>>>>    // Params:
37260>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37260>>>>>    //
37260>>>>>    Procedure UpdateSessionProperties Boolean bClear
37262>>>>>        Handle hoUserDD
37262>>>>>        
37262>>>>>        Get phoUserDD to hoUserDD
37263>>>>>        
37263>>>>>        //  Update user properties
37263>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37265>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37266>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37267>>>>>            Set piUserRights to WebAppUser.Rights
37268>>>>>            
37268>>>>>            Send OnSessionPropertiesSet 
37269>>>>>        End
37269>>>>>>
37269>>>>>        Else Begin
37270>>>>>            Set psUsername to ""
37271>>>>>            Set psLoginName to ""
37272>>>>>            Set piUserRights to 0
37273>>>>>            
37273>>>>>            Send OnSessionPropertiesClear
37274>>>>>        End
37274>>>>>>
37274>>>>>    End_Procedure
37275>>>>>    
37275>>>>>    Procedure OnSessionPropertiesSet
37277>>>>>        //  Empty event stub
37277>>>>>    End_Procedure
37278>>>>>    
37278>>>>>    Procedure OnSessionPropertiesClear
37280>>>>>        //  Empty event stub
37280>>>>>    End_Procedure
37281>>>>>    
37281>>>>>    Procedure EndSession
37283>>>>>        Integer iErr
37283>>>>>        Boolean bLogWebSession
37283>>>>>        Handle hoSessionDD       
37283>>>>>        
37283>>>>>        Get phoSessionDD to hoSessionDD
37284>>>>>        Get pbLogWebSession to bLogWebSession
37285>>>>>        If not bLogWebSession Begin
37287>>>>>            Forward Send EndSession
37289>>>>>            Procedure_Return
37290>>>>>        End
37290>>>>>>
37290>>>>>            
37290>>>>>        //  Check if session exists
37290>>>>>        Send Clear of hoSessionDD
37291>>>>>        Get psSessionKey to WebAppSession.SessionKey
37292>>>>>        
37292>>>>>        Send Find of hoSessionDD EQ Index.1
37293>>>>>        If (Found) Begin
37295>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37296>>>>>            Get Request_Validate of hoSessionDD to iErr
37297>>>>>            If (iErr) Begin
37299>>>>>                // this should not happen. If it does its a programming error
37299>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37300>>>>>>
37300>>>>>                Procedure_Return
37301>>>>>            End
37301>>>>>>
37301>>>>>            Send Request_Save of hoSessionDD
37302>>>>>        End
37302>>>>>>
37302>>>>>    End_Procedure
37303>>>>>
37303>>>>>End_Class
37304>>>>>
