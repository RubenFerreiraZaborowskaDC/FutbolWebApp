37651>>>        Object oCancelChangesBtn is a cWebMenuItem
37653>>>            Set psCSSClass to "WebIcon_Refresh"
37654>>>            Set psCaption to "Clear Changes"
37655>>>            Set peActionDisplay to adMenu
37656>>>            Procedure OnClick
37659>>>                Send RefreshRecord
37660>>>            End_Procedure
37661>>>
37661>>>        End_Object 
37662>>>    End_Object 
37663>>>
37663>>>    Procedure SetActionButtons
37666>>>        tWebNavigateData NavigateData
37666>>>        tWebNavigateData NavigateData
37666>>>        Boolean bHasRecord
37666>>>        Handle hoDD
37666>>>
37666>>>        Get Server to hoDD
37667>>>        Get GetNavigateData to NavigateData
37668>>>        Get HasRecord of hoDD to bHasRecord
37669>>>
37669>>>        // let's hide all buttons and then Show the ones we want
37669>>>        WebSet pbRender of oEditBtn to False
37670>>>        WebSet pbRender of oSaveBtn to False
37671>>>        WebSet pbRender of oCancelChangesBtn to False
37672>>>        WebSet pbRender of oDeleteBtn to False
37673>>>
37673>>>        If (NavigateData.bReadOnly) Begin
37675>>>            WebSet pbRender of oEditBtn to True
37676>>>        End
37676>>>>
37676>>>        Else Begin
37677>>>            WebSet pbRender of oSaveBtn to True
37678>>>            WebSet pbRender of oCancelChangesBtn to True
37679>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37680>>>        End
37680>>>>
37680>>>    End_Procedure
37681>>>
37681>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37684>>>        // Close after save
37684>>>        Send NavigateClose Self
37685>>>    End_Procedure
37686>>>
37686>>>    // this will close the view after a delete
37686>>>    Procedure OnViewDeleted Handle hoDDO
37689>>>        Send NavigateClose Self
37690>>>    End_Procedure
37691>>>
37691>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37694>>>        Case Begin
37694>>>            Case (NavigateData.eNavigateType = nfFromMain)
37696>>>                // If from main, this is a propbably a main file Select to Zoom.
37696>>>                Case Break
37697>>>
37697>>>            Case (NavigateData.eNavigateType = nfFromParent)
37700>>>                // If from parent, this is a constrained drill down.
37700>>>                Case Break
37701>>>
37701>>>            Case (NavigateData.eNavigateType = nfFromChild)
37704>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37704>>>                Case Break
37705>>>
37705>>>            Case Else // must be nfUndefined
37705>>>
37705>>>        Case End
37705>>>
37705>>>        Send SetActionButtons
37706>>>
37706>>>    End_Procedure
37707>>>
37707>>>End_Object 
