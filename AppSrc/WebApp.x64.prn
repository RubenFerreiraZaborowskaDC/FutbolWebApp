37391>>>    Procedure DoLogin
37394>>>        String sLoginName sPassword sPrevStateHash
37394>>>        Boolean bResult
37394>>>        
37394>>>        WebGet psValue of oLoginName to sLoginName
37395>>>        WebGet psValue of oPassword to sPassword
37396>>>        
37396>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37397>>>        
37397>>>        If (bResult) Begin
37399>>>            Send Hide of oLogin
37400>>>            Send ShowHeader of ghoWebApp
37401>>>            WebSet psCSSClass of ghoWebApp to ""
37402>>>            
37402>>>            WebGet psPrevStateHash to sPrevStateHash
37403>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37404>>>            
37404>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37404>>>            WebSet psValue of oLoginName to ""
37405>>>            WebSet psValue of oPassword  to ""
37406>>>            WebSet pbVisible of oWarning to False
37407>>>        End
37407>>>>
37407>>>        Else Begin
37408>>>            WebSet pbVisible of oWarning to True
37409>>>        End
37409>>>>
37409>>>    End_Procedure
37410>>>    
37410>>>    Procedure OnSubmit
37413>>>        Send DoLogin
37414>>>    End_Procedure
37415>>>    
37415>>>    Procedure OnLoad
37418>>>        String sPrevStateHash sView
37418>>>        
37418>>>        Forward Send OnLoad
37420>>>        
37420>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37420>>>        Get StateHash of ghoWebApp to sPrevStateHash
37421>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37422>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37424>>>            WebSet psPrevStateHash to sPrevStateHash
37425>>>        End
37425>>>>
37425>>>        
37425>>>    End_Procedure
